# Credentials for outbound part-data APIs used by the MCP tools.
# Copy to `.env` (gitignored) and fill in. The server reads these at request
# time; real environment variables override values here.

# download_footprint AND download_datasheet — Component Search Engine cookie.
# Copy the `connect.sid` cookie value from a logged-in browser session at
# https://componentsearchengine.com/ (it expires; refresh when downloads fail).
CSE_CONNECT_SID=

# ── Auth (ward) ──────────────────────────────────────────────────────────
# netlisp is a pure resource server; auth is delegated to the wardd auth
# server. If any WARD_* URL is unset, protected requests FAIL CLOSED (503) —
# except the NETLISP_DEV loopback dev bypass, which needs no wardd.

# Verify a browser `ward_session` cookie (LAN-side wardd endpoint).
WARD_VERIFY_URL=http://127.0.0.1:9000/verify
# Where browsers without a session are redirected to sign in (public URL).
WARD_LOGIN_URL=https://ward.eugenepentland.dev/login
# Optional: explicit RFC 9728 authorization-server base for the protected-resource
# metadata. Defaults to stripping the trailing "/login" off WARD_LOGIN_URL, so
# only set this when the login URL does not end in "/login".
# WARD_AUTH_SERVER_URL=https://ward.eugenepentland.dev
# Introspect MCP/API bearer tokens (LAN-only wardd endpoint).
WARD_INTROSPECT_URL=http://127.0.0.1:9000/oauth/introspect
# Service name a bearer's scope must contain to be accepted here.
WARD_SERVICE_NAME=eda
# Verdict-cache TTL in seconds — the upper bound on revocation lag.
WARD_CACHE_TTL_SECS=30
