(import adf5901acpz)
(import res-0402)
(import res-0805)
(import cap-0402)
(import cap-0805)

(design-block "ADF5901 24GHz Tx MMIC"

  (instance "U1" adf5901acpz
    (pin 1 3 6 8 10 12 13 19 33 "GND")
    (pin 4 5 14 16 17 30 "AVDD_TX")
    (pin 2 "TX_OUT1")
    (pin 7 "TX_OUT2")
    (pin 9 "ATEST")
    (pin 11 "LO_OUT")
    (pin 15 "REFIN")
    (pin 18 "VREG")
    (pin 20 "CE") (pin 21 "CLK") (pin 22 "DATA") (pin 23 "LE")
    (pin 24 "DOUT") (pin 25 "MUXOUT")
    (pin 26 "RSET")
    (pin 27 "AUX") (pin 28 "AUXB")
    (pin 29 "VTUNE") (id e33105ce))

  ;; TX_AHI bypass
  (instance "C1" (cap-0402 "100nF")
    (pin 1 "AVDD_TX")
    (pin 2 "GND") (id f8437087))
  (instance "C2" (cap-0402 "1nF")
    (pin 1 "AVDD_TX")
    (pin 2 "GND") (id f82fa4e7))

  ;; AHI bypass
  (instance "C3" (cap-0402 "100nF")
    (pin 1 "AVDD_TX")
    (pin 2 "GND") (id b4a76f27))
  (instance "C4" (cap-0402 "1nF")
    (pin 1 "AVDD_TX")
    (pin 2 "GND") (id ced5c45e))
  (instance "C5" (cap-0402 "10pF")
    (pin 1 "AVDD_TX")
    (pin 2 "GND") (id b30afe87))

  ;; RF_AHI bypass
  (instance "C6" (cap-0402 "100nF")
    (pin 1 "AVDD_TX")
    (pin 2 "GND") (id e1a7d1d4))
  (instance "C7" (cap-0402 "1nF")
    (pin 1 "AVDD_TX")
    (pin 2 "GND") (id c582702a))
  (instance "C8" (cap-0402 "10pF")
    (pin 1 "AVDD_TX")
    (pin 2 "GND") (id c756babc))

  ;; VCO_AHI bypass
  (instance "C9" (cap-0402 "100nF")
    (pin 1 "AVDD_TX")
    (pin 2 "GND") (id a97bf4e4))
  (instance "C10" (cap-0402 "1nF")
    (pin 1 "AVDD_TX")
    (pin 2 "GND") (id cdf19b20))
  (instance "C11" (cap-0402 "10pF")
    (pin 1 "AVDD_TX")
    (pin 2 "GND") (id f8186005))

  ;; VREG bypass
  (instance "C12" (cap-0402 "47nF")
    (pin 1 "VREG")
    (pin 2 "GND") (id e6c28132))
  (instance "C13" (cap-0402 "220nF")
    (pin 1 "VREG")
    (pin 2 "GND") (id c9be2764))

  ;; REFIN network
  (instance "C14" (cap-0402 "1nF")
    (pin 1 "REFIN")
    (pin 2 "REFIN_AC") (id edb64f22))
  (instance "C15" (cap-0402 "1nF")
    (pin 1 "REFIN")
    (pin 2 "REFIN_AC") (id e9570ea6))
  (instance "R2" (res-0402 "5.1k")
    (pin 1 "REFIN")
    (pin 2 "GND") (id d9ba1a93))

  ;; DVDD bypass
  (instance "C16" (cap-0402 "100nF")
    (pin 1 "AVDD_TX")
    (pin 2 "GND") (id ee08d1e0))

  ;; Bias
  (instance "R1" (res-0402 "5.1k")
    (pin 1 "RSET")
    (pin 2 "GND") (id c120d512))

  ;; Loop filter
  (instance "R3" (res-0805 "510R")
    (pin 1 "CPOUT")
    (pin 2 "LF1") (id ec1164e4))
  (instance "R4" (res-0805 "0R")
    (pin 1 "LF1")
    (pin 2 "LF2") (id d962e87b))
  (instance "R5" (res-0805 "0R")
    (pin 1 "LF2")
    (pin 2 "VTUNE") (id f99b1a63))
  (instance "C17" (cap-0805 "3.3nF")
    (pin 1 "LF1")
    (pin 2 "GND") (id c21aaeec))
  (instance "C18" (cap-0805 "220pF")
    (pin 1 "CPOUT")
    (pin 2 "GND") (id c7fdb644))
  (instance "C19" (cap-0805 "100pF")
    (pin 1 "LF2")
    (pin 2 "GND") (id a165a06a))

  ;; Ports
  (port "AVDD_TX" in (rated 3.15 3.45))
  (port "REFIN"   in)
  (port "CPOUT"   in)
  (port "TX_OUT1" out)
  (port "TX_OUT2" out)
  (port "LO_OUT"  out)
  (port "AUX"     out)
  (port "AUXB"    out)
  (port "CE"      in)
  (port "CLK"     in)
  (port "DATA"    in)
  (port "LE"      in)
  (port "DOUT"    out)
  (port "MUXOUT"  out)
  (port "GND"     bidi)

  ;; Groups
  (group "TX_AHI Bypass" ("C1" "C2"))
  (group "AHI Bypass" ("C3" "C4" "C5"))
  (group "RF_AHI Bypass" ("C6" "C7" "C8"))
  (group "VCO_AHI Bypass" ("C9" "C10" "C11"))
  (group "VREG Bypass" ("C12" "C13"))
  (group "REFIN Network" ("C14" "C15" "R2"))
  (group "Loop Filter" ("R3" "R4" "R5" "C17" "C18" "C19")))
