#!/bin/sh

# Preserve the machine-local conflicted-merge deployment hook while
# core.hooksPath points at the committed worktree hooks.
set -eu

common_dir=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || exit 0
local_hook="$common_dir/hooks/post-commit"
[ ! -x "$local_hook" ] || exec "$local_hook" "$@"
