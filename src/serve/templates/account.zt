const auth_mod = @import("../auth.zig");
const oauth_store = @import("../oauth_store.zig");
const users_mod = @import("../users.zig");
const assets_css = @import("../assets_css.zig");
const home_tmpl = @import("pages.zig");

// <style> and <script> are zt raw-text elements — expressions inside aren't
// interpolated, so the inline auth blocks ship as single raw chunks emitted
// via `{!...}` outside the tags. The page-specific CSS/JS are linked
// externally and served by `static_assets.staticAsset` at /static/.
const AUTH_STYLE_BLOCK: []const u8 = "<style>" ++ auth_mod.PAGE_STYLE ++ assets_css.NAVBAR_CSS ++ "</style>";
const AUTH_SCRIPT_BLOCK: []const u8 = "<script>" ++ auth_mod.B64URL_JS ++ "</script>";

const ROLE_OPTIONS = [_][]const u8{ "admin", "writer", "reader" };

pub templ Account(
    email: []const u8,
    role: users_mod.Role,
    is_admin: bool,
    user_list: []const users_mod.User,
    clients: []const oauth_store.Client,
) {
    <!DOCTYPE html>
    <html>
        <head>
            <meta name="viewport" content="width=device-width,initial-scale=1" />
            <title>Account — Netlisp</title>
            {!AUTH_STYLE_BLOCK}
            <link rel="stylesheet" href="/static/account_page.css" />
        </head>
        <body>
            @home_tmpl.Navbar("account")
            <div class="wrap">
                <div class="user-bar">
                    <span class="email">
                        Signed in as {email}
                        <span class="role-pill role-{role.toString()}">{role.toString()}</span>
                    </span>
                    <button id="logout-btn">Sign out</button>
                </div>
                <h1 style="margin-bottom:1.5rem">Account</h1>

                @PasskeysCard()
                @PasswordCard()

                if (is_admin) {
                    @InviteCard()
                    @UsersCard(user_list, email)
                }

                @OAuthClientsCard(clients)
            </div>
            {!AUTH_SCRIPT_BLOCK}
            <script src="/static/account_page.js"></script>
        </body>
    </html>
}

pub templ PasskeysCard() {
    <div class="card">
        <h2>Passkeys</h2>
        <p class="muted">Devices that can sign in to this account.</p>
        <div id="passkey-list"></div>
        <button class="btn-primary" id="add-passkey-btn" style="margin-top:8px">Add passkey on this device</button>
    </div>
}

pub templ PasswordCard() {
    <div class="card">
        <h2>Password</h2>
        <p class="muted" id="pw-help">Set a password as a fallback in case your passkey is lost.</p>
        <input type="password" id="pw-input" placeholder="New password (min 8 chars)" minlength="8" autocomplete="new-password" />
        <button class="btn-primary" id="pw-btn">Set password</button>
    </div>
}

pub templ InviteCard() {
    <div class="card">
        <h2>Invite</h2>
        <p class="muted">Generate a one-time link (valid 7 days). The role is assigned to whoever registers through the link.</p>
        <label>Role</label>
        <select id="invite-role">
            <option value="writer" selected>writer (can edit)</option>
            <option value="reader">reader (view only)</option>
            <option value="admin">admin</option>
        </select>
        <div style="margin-top:10px"><button id="invite-btn">Create invite link</button></div>
        <div id="invite-out"></div>
    </div>
}

pub templ UsersCard(user_list: []const users_mod.User, current_email: []const u8) {
    <div class="card">
        <h2>Users</h2>
        <p class="muted">
            Every user registered on this server.
            Admins can change roles or remove users
            (which revokes their passkeys, sessions, and OAuth clients).
        </p>
        <table>
            <tr><th>Email</th><th>Role</th><th>Joined</th><th></th></tr>
            for (user_list) |u| {
                @UserRow(u, current_email)
            }
        </table>
    </div>
}

pub templ UserRow(u: users_mod.User, current_email: []const u8) {
    <tr>
        <td>{u.email}</td>
        <td>
            if (std.mem.eql(u8, u.email, current_email)) {
                <span class="role-pill role-{u.role.toString()}">{u.role.toString()}</span>
                <span class="muted">(you)</span>
            } else {
                <select onchange="updateRole(this,'{u.email}')">
                    for (ROLE_OPTIONS) |r| {
                        <option value={r} selected={if (std.mem.eql(u8, r, u.role.toString())) "" else null}>{r}</option>
                    }
                </select>
            }
        </td>
        <td class="muted"><span data-ts={u.created_at}></span></td>
        <td>
            if (!std.mem.eql(u8, u.email, current_email)) {
                <button class="btn-danger" onclick="deleteUser('{u.email}')">Delete</button>
            }
        </td>
    </tr>
}

pub templ OAuthClientsCard(clients: []const oauth_store.Client) {
    <div class="card">
        <h2>MCP OAuth Clients</h2>
        <p class="muted">Register a Claude Code / Claude.ai MCP client. Each client gets credentials you paste into the remote-MCP connector.</p>
        if (clients.len == 0) {
            <p class="muted">No clients yet — create one below.</p>
        } else {
            <table>
                <tr><th>Name</th><th>Client ID</th><th>Redirect URI</th><th></th></tr>
                for (clients) |c| {
                    @ClientRow(c)
                }
            </table>
        }
        @ClientCreateForm()
    </div>
    <div class="status" id="status"></div>
}

pub templ ClientRow(c: oauth_store.Client) {
    <tr>
        <td>{c.name}</td>
        <td><code>{c.id}</code></td>
        <td><code>{c.redirect_uri}</code></td>
        <td>
            <button class="btn-danger" onclick="revokeClient('{c.id}')">Revoke</button>
        </td>
    </tr>
}

pub templ ClientCreateForm() {
    <h3 style="margin-top:18px;font-size:0.95rem;color:#f0f6fc">Create new client</h3>
    <form onsubmit="return createClient(event)">
        <label>Name (for your reference)</label>
        <input type="text" id="client-name" placeholder="e.g. My laptop — Claude Code" required />
        <label>Redirect URI (must match your MCP client's OAuth callback exactly)</label>
        <input type="text" id="client-redirect" value="https://claude.ai/api/mcp/auth_callback" required />
        <p class="muted" style="margin-bottom:8px">
            Common values:
            <code>https://claude.ai/api/mcp/auth_callback</code> (Claude.ai web),
            <code>http://localhost:8080/callback</code> (Claude Code CLI default).
        </p>
        <button type="submit" class="btn-primary">Create client</button>
    </form>
    <div id="client-secret-output"></div>
}
