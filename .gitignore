zig-out/
.zig-cache/
*.o
*.swp
*~

# Python bytecode
__pycache__/
*.pyc

# Board-specific design data — the user's projects, not the eda tool itself.
# Everything under projects/ (designs, libraries, history, reviews, OAuth
# state, edit history) lives on disk but is not tracked. The tracked tool is
# src/, build.zig, SPEC.md, docs/, etc.
/projects/

# Guardian runtime database
guardian_runtime.db

# Guardian per-build input cache (regenerated by every build)
.guardian/cache/

# Loose root-level scratch files
/ADC.md
/ad7380-4.pdf

# Claude Code worktree metadata (per-machine; not part of the project)
.claude/worktrees/
# Machine-local symlinks for the ward path dep (see build.zig.zon)
.claude/ward
.claude/canopy

# Local credentials for outbound part-data APIs (see .env.example)
.env
